# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Force LF for all Python and config files
*.py        text eol=lf
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf

# Force binary for images so Git never corrupts them
*.jpg       binary
*.jpeg      binary
*.png       binary
*.webp      binary
*.gif       binary
*.ico       binary

# Force binary for archives
*.gz        binary
*.zip       binary
*.whl       binary

# Don't let the template HTML dominate the language stats
*.html      linguist-detectable=false